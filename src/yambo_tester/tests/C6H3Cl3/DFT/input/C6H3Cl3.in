ndtset 2
iomode 3

#Dataset 1 : usual self-consistent calculation
kptopt 1          # Option for the automatic generation of k points,
ngkpt  1 1 1
nshiftk 1 
shiftk 0.0 0.0 0.0
diemac1 12.0       # Although this is not mandatory, it is worth to
tolvrs1 1.0d-8
istwfk2 1*1
# Definition of the SCF procedure
iscf2    -2             # Non self-consistent calculation
getden2  -1             # Read previous density file
getwfk2 -1 
tolwfr2  1.0d-12        # Still get it converged
nstep2 2000
nband2  50
#nbandkss2 50
#kssform2 3
#Definition of the unit cell
acell 10.00 6.00 10.00 Angstrom
rprim 1.0000 0.0000 0.0000
      0.0000 1.0000 0.0000
      0.0000 0.0000 1.0000
#Definition of the atom types
ntypat 3          
znucl 6 1 17   
#Definition of the atoms
natom 12           
typat 3 3 3 1 1 1 1 1 1 2 2 2  
      xred   -4.8700000000E-02  3.8500000000E-02 -3.3580000000E-02
              4.2846000000E-01 -3.8053333333E-01 -1.4290000000E-02
              1.9074000000E-01 -1.0871666667E-01  4.4196000000E-01
              8.3240000000E-02 -6.5800000000E-02  5.7510000000E-02
              2.9683000000E-01 -2.5340000000E-01  6.6180000000E-02
              1.9042000000E-01 -1.3160000000E-01  2.7040000000E-01
              1.8991000000E-01 -1.6891666667E-01 -7.6800000000E-03
              8.3490000000E-02 -4.7150000000E-02  1.9655000000E-01
              2.9708000000E-01 -2.3475000000E-01  2.0522000000E-01
              1.8972000000E-01 -1.8343333333E-01 -1.1612000000E-01
              2.9000000000E-04  3.3266666667E-02  2.4739000000E-01
              3.8048000000E-01 -3.0065000000E-01  2.6282000000E-01
#Definition of the planewave basis set
ecut 20.0
