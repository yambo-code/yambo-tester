# ==== OpenMP ===
HF_lXC_Threads=0                            # [HF_lXC] Number of threads
#
# ==== MPI (V=parallel) ===
NLogCPUs=0                                  # Live-timing CPU`s (0 for all)
PAR_def_mode= "balanced"                    # Default distribution mode ("balanced"/"memory"/"workload"/"KQmemory")
HFlXC_CPU= ""                               # CPUs for each role
HFlXC_ROLEs= ""                             # CPUs roles (qp,g,q,b)
